# ============================================
# Supabase
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# Email (Resend)
# ============================================
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# AI (StringingMode recommendations)
# ============================================
AI_PROVIDER=openai
AI_API_KEY=sk-your-key
AI_MODEL=gpt-4o-mini

# ============================================
# App
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Stripe — required for paid plans, Day Pass, billing portal
# ============================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price IDs from your Stripe Dashboard (one Pro plan + Day Pass):
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_ANNUAL=price_xxx
STRIPE_PRICE_DAY_PASS=price_xxx

# ============================================
# Twilio — Phase 3 (SMS notifications)
# ============================================
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+15551234567

# ============================================
# ElevenLabs — Phase 4 (DJ Console announcer)
# ============================================
ELEVENLABS_API_KEY=xxx
ELEVENLABS_VOICE_ID=nPczCjzI2devNBz1zQrb  # Brian — hype announcer
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ============================================
# Pixabay Music — Phase 4 (DJ Console walkout songs)
# ============================================
PIXABAY_API_KEY=xxx
